# .env — Environment Variables for local development
# Copy this file to .env and customize values before running.
# NEVER commit real secrets to git!

# JWT Secret — must be the same across ALL services
JWT_SECRET=eticaret-super-secret-key-CHANGE-IN-PRODUCTION-minimum-32-chars

# Service Ports (defaults — change if ports are in use)
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
ADDRESS_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=eticaret

# Inter-service URLs (used only when running without Docker)
AUTH_SERVICE_URL=http://localhost:8081
PRODUCT_SERVICE_URL=http://localhost:8082
ADDRESS_SERVICE_URL=http://localhost:8083
ORDER_SERVICE_URL=http://localhost:8084
